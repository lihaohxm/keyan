    "h_ue_m": 1.5,
    "ris_placement": "圆周均匀分布，角度 phi_l = 2π(l-1)/L",
    "ue_placement": "圆环均匀分布，每次MC重新采样",
    "mc_rule": "每次MC重新采样UE位置+小尺度衰落；RIS/BS固定位置"
  },
  
  "channel_parameters": {
    "d0_m": 1,
    "kappa_dB": -30,
    "alpha_BU": 4.5,
    "alpha_BR": 2.2,
    "alpha_RU": 2.2,
    "fading_model": "Rayleigh",
    "large_scale_formula": "zeta = 10^(kappa_dB/10) * (d0/d)^alpha",
    "small_scale_formula": "h ~ CN(0, zeta * I)"
  },
  
  "noise_parameters": {
    "sigma2_dBm": -70,
    "description": "等效干扰+噪声功率 (Interference+Noise)，用于刻画强干扰环境",
    "note": "非纯热噪声 (N0*B ≈ -114 dBm @ B=1MHz)"
  },
  
  "ris_parameters": {
    "eta": 0.8,
    "description": "反射效率，替代旧的ris_gain=1000",
    "note": "阵列增益由N_RIS相干叠加自然产生，避免双重增益",
    "phase_modes": ["mm", "align", "random"]
  },
  
  "qoe_parameters": {
    "proxy_mode": "sigmoid",
    "proxy_formula": "xi = 1/(1+exp(-c*(gamma_dB-gamma0)))",
    "proxy_c": 0.6,
    "proxy_gamma0_dB": 0,
    "semantic_distortion": "D = 1 - xi",
    "deadlines_ms": [2, 10],
    "dmax": 0.30,
    "beta_d": 0.1,
    "beta_s": 0.1,
    "b_d": 10,
    "b_s": 10,
    "default_weights": [0.5, 0.5]
  },
  
  "task_parameters": {
    "default_task_size_bit": 3000,
    "delay_formula": "T_k = S_k / (B * log2(1 + gamma_k)) + prop_delay_k",
    "hetero_urllc_task_size_bit": 1500,
    "hetero_semantic_task_size_bit": 6000
  },
  
  "hetero_user_config": {
    "urllc_count": 4,
    "semantic_count": 8,
    "urllc_weights": [0.8, 0.2],
    "urllc_deadline_ms": 2,
    "urllc_task_size_bit": 1500,
    "semantic_weights": [0.2, 0.8],
    "semantic_deadline_ms": 10,
    "semantic_task_size_bit": 6000
  },
  
  "ga_parameters": {
