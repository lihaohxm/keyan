+function theta_new = ris_phase_mm(cfg, ch, assign, V, weights, max_iter, theta_init)
+%RIS_PHASE_MM 严格 RIS 相位 MM 优化 (基于 RSMA-WMMSE 诱导的 UQP)
+%
+% 实现论文 3.3 节算法的核心逻辑：
+%   - 目标: 最小化加权 WMSE
+%   - 约束: 单位模相位约束 |exp(j*theta)| = 1
+
+num_ris = cfg.num_ris;
+n_ris = cfg.n_ris;
+num_users = cfg.num_users;
+v_c = V.v_c;
+V_p = V.V_p;
+
+if nargin < 6
+    max_iter = 5;
+end
+
+if nargin < 7
+    theta_init = [];
+end
+
+% Use provided initialization if available (AO should warm-start from current theta).
+if ~isempty(theta_init)
+    theta_new = theta_init;
+else
+    theta_new = ch.theta;
+end
+
+% Basic safety
+if size(theta_new, 1) ~= n_ris || size(theta_new, 2) ~= num_ris
+    theta_new = ch.theta;
+end
+
+% 逐个 RIS 更新 (块坐标下降)
+for l = 1:num_ris
+    users_l = find(assign == l);
+    if isempty(users_l)
+        % No associated users -> keep the previous phase.
+        continue;
+    end
+
+    % 构造针对第 l 块 RIS 的聚合相位向量
+    v_agg = zeros(n_ris, 1);
+    
+    % 遍历所有用户，累加他们对该 RIS 的相位对齐偏好
+    for k = 1:num_users
+        if assign(k) ~= l
+            continue;
+        end
+        % 获取该用户受影响的权重 (QoE 驱动)
+        qoe_w = weights(k);
+        
+        % 计算不含当前 RIS 贡献的等效信道项 (直连 + 其他 RIS)
+        % NOTE: In this repo's association model, each user is aided by at most ONE RIS.
+        % For user k associated with RIS-l, the "other" channel is therefore direct only.
+        h_others = ch.h_d(:, k);
+        
+        % 级联信道矩阵项 M_kl = G_l * diag(h_rk,l)
+        M_kl = cfg.ris_gain * ch.G(:, :, l) * diag(ch.H_ris(:, k, l));
+        
+        % 处理公共流 v_c
+        % 目标是让 M_kl * v_l 产生的信号与 h_others 产生的信号在 v_c 方向上同相
+        alpha_c = h_others' * v_c;
+        beta_c_vec = (v_c' * M_kl).'; % 这是一个 n_ris x 1 向量
+        % 相位补偿项: 使 exp(j*theta) * beta_c_vec 与 alpha_c 同相
+        v_agg = v_agg + qoe_w * exp(1j * (angle(alpha_c + cfg.eps) - angle(beta_c_vec + cfg.eps)));
+        
+        % 处理私有流 v_k (只对齐用户 k 自己的私有流)
+        vk = V_p(:, k);
+        alpha_p = h_others' * vk;
+        beta_p_vec = (vk' * M_kl).';
+        v_agg = v_agg + qoe_w * exp(1j * (angle(alpha_p + cfg.eps) - angle(beta_p_vec + cfg.eps)));
+    end
+    
+    % 单位模投影更新
+    if norm(v_agg) > cfg.eps
+        theta_new(:, l) = exp(1j * angle(v_agg));
+    end
+end
+end
